}

<!-- ─────────────────────────────────────────────
     Top Navigation
     ───────────────────────────────────────────── -->
<nav class="navbar px-4 px-md-5 py-4">
    <div class="container-xl d-flex align-items-center justify-content-between w-100">

        <!-- Brand -->
        <div class="d-flex align-items-center gap-2">
            <div class="nav-logo-box">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <img src="~/image/logo.png" alt="Logo" style="width: 100%; height: 100%; object-fit: cover;">
                </a>
            </div>
            <span class="nav-brand-name">ccs sit-in</span>
        </div>

        <!-- Nav links (hidden on small screens) -->
        <div class="d-none d-md-flex align-items-center gap-4">
            <a class="nav-link-custom" asp-controller="Home" asp-action="Index">Home</a>
            <a class="nav-link-custom" asp-controller="Home" asp-action="Community">Community</a>
            <a class="nav-link-custom" asp-controller="Home" asp-action="About">About</a>
        </div>

        <div class="d-flex align-items-center gap-3">

            <a asp-controller="Account"
               asp-action="Login"
               style="color: var(--accent-dark); font-size: 0.875rem; font-weight: 700; text-decoration: none;">
                Log In
            </a>

            <!-- Register Action -->
            <a asp-controller="Account"
               asp-action="Register"
               class="btn-register-nav"
               style="text-decoration: none;">
                Register
            </a>
        </div>


    </div>
</nav>