
@{
    ViewData["Title"] = "Register";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>CCS SIT-IN | Register</title>

    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <!-- Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/Register.css" asp-append-version="true" />
</head>
<body>

    <!-- ─────────────────────────────────────────────
         Header — homepage Bootstrap style


    <!-- ─────────────────────────────────────────────
         Main Registration Section
         ───────────────────────────────────────────── -->
    <main class="d-flex flex-column align-items-center justify-content-center px-3 py-5">

        <div class="register-card">

            <!-- Header Text -->
            <div class="mb-5 text-center">
                <h1 class="card-title">Create your account</h1>
                <p class="card-subtitle">Join the CCS SIT-IN community and manage your sessions easily.</p>
            </div>

            <!-- Registration Form -->
            <form onsubmit="return false;">
                <div class="d-flex flex-column gap-4">

                    <!-- ID Number -->
                    <div>
                        <label class="form-label-custom" for="id-number">ID Number</label>
                        <input class="input-pill" id="id-number" type="text" placeholder="e.g. 2023-0001" />
                    </div>

                    <!-- Name Grid -->
                    <div class="row g-4">
                        <div class="col-12 col-md-6">
                            <label class="form-label-custom" for="first-name">First Name</label>
                            <input class="input-pill" id="first-name" type="text" placeholder="John" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label-custom" for="middle-name">Middle Name</label>
                            <input class="input-pill" id="middle-name" type="text" placeholder="Quincy" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label-custom" for="last-name">Last Name</label>
                            <input class="input-pill" id="last-name" type="text" placeholder="Doe" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label-custom" for="email">Email Address</label>
                            <input class="input-pill" id="email" type="email" placeholder="john.doe@university.edu" />
                        </div>
                    </div>

                    <!-- Academic Info Grid -->
                    <div class="row g-4">
                        <div class="col-12 col-md-6">
                            <label class="form-label-custom" for="course">Course</label>
                            <div class="select-wrapper">
                                <select class="input-pill" id="course">
                                    <option value="">Select your course</option>
                                    <option value="BSCS">BS Computer Science</option>
                                    <option value="BSIT">BS Information Technology</option>
                                    <option value="BSIS">BS Information Systems</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label-custom" for="year-level">Course Level (Year)</label>
                            <div class="select-wrapper">
                                <select class="input-pill" id="year-level">
                                    <option value="">Select year level</option>
                                    <option value="1">1st Year</option>
                                    <option value="2">2nd Year</option>
                                    <option value="3">3rd Year</option>
                                    <option value="4">4th Year</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Home Address -->
                    <div>
                        <label class="form-label-custom" for="address">Home Address</label>
                        <input class="input-pill" id="address" type="text" placeholder="Unit, Street, Barangay, City" />
                    </div>

                    <!-- Password Grid -->
                    <div class="row g-4 pb-2">
                        <div class="col-12 col-md-6">
                            <label class="form-label-custom" for="password">Password</label>
                            <input class="input-pill" id="password" type="password" placeholder="••••••••" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label-custom" for="repeat-password">Repeat Password</label>
                            <input class="input-pill" id="repeat-password" type="password" placeholder="••••••••" />
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="pt-2 d-flex flex-column gap-3">
                        <button class="btn-register-submit" type="submit">
                            Register Account
                        </button>
                        <p class="text-center mb-0" style="color: #475569; font-weight: 500;">
                            Already have an account?
                            <a class="link-primary" href="#">Log in here</a>
                        </p>
                    </div>

                </div>
            </form>

        </div><!-- /register-card -->
        <!-- Decoration / Footer -->
        <div class="mt-5 text-center" style="color: #94a3b8; font-size: 0.875rem;">
            <p class="mb-0">© 2024 CCS SIT-IN Management System. All rights reserved.</p>
        </div>

    </main>

    <!-- Bootstrap 5.3 JS Bundle (Popper included) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

